<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
    <url>
        <loc>{{ absolute_url(path('public_news_index')) }}</loc>
    </url>
    {% for news in newsEntries %}
        <url>
            <loc>{{ news.url }}</loc>
            <lastmod>{{ news.lastModified }}</lastmod>
        </url>
    {% endfor %}
</urlset>